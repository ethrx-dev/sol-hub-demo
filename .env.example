# SOL Hub Environment Variables
# Copy relevant sections to apps/api/.env and apps/web/.env

## API — copy to apps/api/.env
DATABASE_URL=postgresql+asyncpg://solhub:solhub_dev@localhost:5432/solhub
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-this-to-a-random-secret
ADMIN_SEED_KEY=change-this-to-a-secure-admin-key
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=solhub
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENTRY_DSN=

## Web — copy to apps/web/.env
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_ENABLED_FEATURES=connections

# Shapo.io Testimonials (https://shapo.io)
# Get your widget ID from the Shapo dashboard after signing up
# NEXT_PUBLIC_SHAPO_WIDGET_ID=abc123def456
# Get your form ID to enable testimonial submission on the testimonials page
# NEXT_PUBLIC_SHAPO_FORM_ID=abc123def456
RESEND_API_KEY=
# EMAIL_FROM=SOL Hub <noreply@solhub.com>
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
